{
  "name": "slideck",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "pnpm --filter @slideck/web dev",
    "build": "pnpm --filter @slideck/web build && pnpm --filter @slideck/cli build",
    "build:web": "pnpm --filter @slideck/web build",
    "build:cli": "pnpm --filter @slideck/cli build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "fmt": "prettier --write \"packages/*/src/**/*.{ts,svelte,css}\"",
    "cli": "pnpm --filter @slideck/cli start"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.55.9",
    "typescript": "^6.0.3"
  }
}
